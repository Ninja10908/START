local function getBaseIdx(pos)
    local c, d = 1, math.huge
    for i, p in pairs(LOW) do
        local dist = (Vector2.new(pos.X, pos.Z) - Vector2.new(p.X, p.Z)).Magnitude
        if dist < d then d = dist; c = i end
    end
    return c
end

local function walk(sec)
    local c = LP.Character
    local h = c:FindFirstChild("Humanoid")
    local hrp = c:FindFirstChild("HumanoidRootPart")
    local lv = hrp.CFrame.LookVector
    local start = os.clock()
    local conn
    conn = RS.RenderStepped:Connect(function()
        if os.clock() - start >= sec then
            conn:Disconnect()
            h:Move(Vector3.zero, false)
            return
        end
        h:Move(lv, false)
    end)
end

local function clone()
    if _G.isCloning then return end
    _G.isCloning = true
    unat()
    local tool = "Quantum Cloner"
    local c = LP.Character
    if not c then _G.isCloning = false return end
    
    local t = LP.Backpack:FindFirstChild(tool) or c:FindFirstChild(tool)
    local h = c:FindFirstChild("Humanoid")
    
    if t and h then
        h:EquipTool(t)
        task.wait(0.01)
        
        local vs = workspace.CurrentCamera.ViewportSize
        local vim = S.VIM
        local x = vs.X * 0.1
        local y = vs.Y * 0.9
        vim:SendMouseButtonEvent(x, y, 0, true, game, 1)
        vim:SendMouseButtonEvent(x, y, 0, false, game, 1)
        
        local clone = ("%*_Clone"):format(LP.UserId)
        local appeared = false
        local timeout = 5
        local start = tick()
        
        while tick() - start < timeout do
            if workspace:FindFirstChild(clone) then
                appeared = true
                break
            end
            task.wait(0.1)
        end
        
        if appeared then
            task.wait(0.1)
            
            local pg = LP:FindFirstChild("PlayerGui")
            local tf = pg and pg:FindFirstChild("ToolsFrames")
            local qc = tf and tf:FindFirstChild("QuantumCloner")
            local tp = qc and qc:FindFirstChild("TeleportToClone")

            if tp and tp.Visible then
                local old = S.GS.SelectedObject
                S.GS.SelectedObject = tp
                task.wait(0.01)
                
                vim:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
                task.wait(0.01)
                vim:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
                
                task.wait(0.1)
                S.GS.SelectedObject = old
            end
        end
    end
    
    _G.isCloning = false
end

_G._isPlotUnlocked = function(plot)
    local ok, res = pcall(function()
        local plots = W:FindFirstChild("Plots")
        if not plots then return false end
        local p = plots:FindFirstChild(plot)
        if not p then return false end
        local u = p:FindFirstChild("Unlock")
        if not u then return true end
        local items = {}
        for _, it in pairs(u:GetChildren()) do
            local pos = nil
            if it:IsA("Model") then pcall(function() pos = it:GetPivot().Position end)
            elseif it:IsA("BasePart") then pos = it.Position end
            if pos then table.insert(items, {Obj = it, H = pos.Y}) end
        end
        table.sort(items, function(a, b) return a.H < b.H end)
        if #items == 0 then return true end
        local door = items[1].Obj
        for _, d in ipairs(door:GetDescendants()) do
            if d:IsA("ProximityPrompt") and d.Enabled then return false end
        end
        for _, c in ipairs(door:GetChildren()) do
            if c:IsA("ProximityPrompt") and c.Enabled then return false end
        end
        return true
    end)
    return ok and res or false
end

local function tp()
    if isMoving then return end

    local target = nil
    if C.AutoTPPriority then
        local best = nil
        local cache = Shared.Cache
        if cache and type(cache) == "table" then
            for _, name in ipairs(PRIO) do
                local s = name:lower()
                for _, a in ipairs(cache) do
                    if a and a.name and a.name:lower() == s and a.owner ~= LP.Name then
                        best = a
                        break
                    end
                end
                if best then break end
            end
            if not best then
                for _, a in ipairs(cache) do
                    if a and a.owner ~= LP.Name then
                        best = a
                        break
                    end
                end
            end
        end
        if best then
            target = best
        else
            if not Shared.Sel then return end
            target = Shared.Sel.animalData
        end
    else
        if not Shared.Sel then return end
        target = Shared.Sel.animalData
    end
    if not target then return end

    local c = LP.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    local h = c and c:FindFirstChild("Humanoid")
    
    if not hrp or not h or h.Health <= 0 then return end
    
    isMoving = true
    
    local part = findAdr(target)
    if not part then 
        isMoving = false
        return 
    end
    
    local pos = part.Position
    local tool = getTool()
    local t = LP.Backpack:FindFirstChild(tool) or c:FindFirstChild(tool)

    if t then h:EquipTool(t) end
    task.wait(0.01)
    local isHigh = pos.Y > 10
    local idx = getBaseIdx(pos)
    local base = isHigh and HIGH[idx] or LOW[idx]
    
    local minH = 50
    local targetH = math.max(base.Y, minH)

    local jump = tick()
    while hrp.Position.Y < targetH and (tick() - jump) < 3 do
        hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 200, hrp.AssemblyLinearVelocity.Z)
        RS.Heartbeat:Wait()
    end

    for i = 1, 10 do
        hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
        if (hrp.Position - base).Magnitude > 3 then
            hrp.CFrame = CFrame.new(base)
            task.wait(0.05)
        end
    end

    if not isHigh then
        local best = CLONE[1]
        local min = math.huge
        for _, v in ipairs(CLONE) do
            local d = (part.Position - v).Magnitude
            if d < min then min = d; best = v end
        end
        for i = 1, 6 do
            if (hrp.Position - best).Magnitude > 3 then
                hrp.CFrame = CFrame.new(best)
                task.wait(0.05)
            end
        end
    end

    local bestFace = FACE[1]
    local minFace = math.huge
    for _, v in ipairs(FACE) do
        local d = (hrp.Position - v).Magnitude
        if d < minFace then
            minFace = d
            bestFace = v
        end
    end

    task.wait(0.1)
    hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(bestFace.X, hrp.Position.Y, bestFace.Z))
    if isHigh or not _G._isPlotUnlocked(target.plot) then
        walk(0.4)
        task.wait(0.4)
        clone()
        task.wait(0.3)
    end
    task.wait(0.15)

    if t then h:EquipTool(t) end

    local vert = part.Position.Y - hrp.Position.Y

    if vert > 2 then
        local air = Vector3.new(part.Position.X, part.Position.Y - 8, part.Position.Z)
        
        local plat = Instance.new("Part")
        plat.Name = "jacck"
        plat.Size = Vector3.new(4, 1, 4)
        plat.Position = air - Vector3.new(0, 5, 0)
        plat.Material = Enum.Material.Neon
        plat.Anchored = true
        plat.CanCollide = true
        plat.Transparency = 1
        plat.Parent = W
        
        RS.Heartbeat:Wait()
        
        for i = 1, 10 do
            if not LP:GetAttribute("Stealing") then
                hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
                hrp.CFrame = CFrame.new(air)
                task.wait(0.05)
            end
        end
        
        task.spawn(function()
            local start = tick()
            while tick() - start < 20 do
                if LP:GetAttribute("Stealing") then break end
                task.wait(0.1)
            end
            plat:Destroy()
        end)
    else
        for i = 1, 10 do
            if LP:GetAttribute("Stealing") then break end
            hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
            if (hrp.Position - part.Position).Magnitude > 3 then
                hrp.CFrame = CFrame.new(part.Position)
                task.wait(0.05)
            end
            task.wait(0.05)
        end
    end
    
    isMoving = false
end

