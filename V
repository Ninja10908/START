local function unat()
    local c = LP.Character
    if not c then return end
    
    local h = c:FindFirstChild("Humanoid")
    if not h then return end
    
    h:UnequipTools()
    
    for _, t in ipairs(c:GetChildren()) do
        if t:IsA("Tool") then
            t.Parent = LP.Backpack
        end
    end
    
    task.wait(0.05)
end

local D
D = setmetatable({}, {
    __index = function(S, ez)
        local Net = RS2.Packages.Net
        local p, path
        if     ez:sub(1,3) == "RE/" then p = "RE/";  path = ez:sub(4)
        elseif ez:sub(1,3) == "RF/" then p = "RF/";  path = ez:sub(4)
        else return nil end
        local R
        for i, v in Net:GetChildren() do
            if v.Name == ez then
                R = Net:GetChildren()[i + 1]
                break
            end
        end
        if R and not rawget(D, ez) then rawset(D, ez, R) end
        return rawget(D, ez)
    end
})

