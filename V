local function findAdr(ad)
    if not ad then return nil end
    local plot = W:FindFirstChild("Plots") and W.Plots:FindFirstChild(ad.plot)
    if plot then
        local pods = plot:FindFirstChild("AnimalPodiums")
        if pods then
            local pod = pods:FindFirstChild(ad.slot)
            if pod then
                local b = pod:FindFirstChild("Base")
                if b then
                    local s = b:FindFirstChild("Spawn")
                    if s then return s end
                    return b:FindFirstChildWhichIsA("BasePart") or b
                end
            end
        end
    end
    return nil
end

