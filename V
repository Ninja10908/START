task.spawn(function()
    local Packs = RS2:WaitForChild("Packages")
    local Datas = RS2:WaitForChild("Datas")
    local Shared2 = RS2:WaitForChild("Shared")
    local Utils = RS2:WaitForChild("Utils")

    local Sync = require(Packs:WaitForChild("Synchronizer"))
    local Animals = require(Datas:WaitForChild("Animals"))
    local AnimShared = require(Shared2:WaitForChild("Animals"))
    local Num = require(Utils:WaitForChild("NumberUtils"))

    local cache = {}
    Shared.Cache = cache

    local last = {}
    local function getHash(al)
        if not al then return "" end
        local h=""
        for s,d in pairs(al) do 
            if type(d)=="table" then 
                h=h..tostring(s)..tostring(d.Index)..tostring(d.Mutation) 
            end 
        end
        return h
    end

    local function scan(plot)
        local changed = false
        pcall(function()
            local ch = Sync:Get(plot.Name)
            if not ch then return end
            local al = ch:Get("AnimalList")
            local hash = getHash(al)
            if last[plot.Name]==hash then return end
            last[plot.Name]=hash
            changed=true
            for i=#cache,1,-1 do 
                if cache[i].plot==plot.Name then 
                    table.remove(cache,i) 
                end 
            end
            local owner = ch:Get("Owner")
            if not owner or not P:FindFirstChild(owner.Name) then return end
            local ownerName = owner.Name or "Unknown"
            if not al then return end
            for slot, ad in pairs(al) do
                if type(ad)=="table" then
                    local aName, aInfo = ad.Index, Animals[ad.Index]
                    if aInfo then
                        local mut = ad.Mutation or "None"
                        if mut == "Yin Yang" then mut = "YinYang" end
                        local gen = AnimShared:GetGeneration(aName, ad.Mutation, ad.Traits, nil)
                        local gt = "$"..Num:ToString(gen).."/s"
                        table.insert(cache, {
                            name=aInfo.DisplayName or aName, 
                            genText=gt, 
                            genValue=gen,
                            mutation=mut, 
                            owner=ownerName,
                            plot=plot.Name, 
                            slot=tostring(slot), 
                            uid=plot.Name.."_"..tostring(slot)
                        })
                    end
                end
            end
        end)
        if changed then
            table.sort(cache, function(a,b) return a.genValue>b.genValue end)
            if cache and #cache > 0 then
                Shared.Sel = cache[1]
            end
        end
    end

    local function listen(plot)
        local ch, retries = nil, 0
        while not ch and retries<50 do
            local ok, r = pcall(function() return Sync:Get(plot.Name) end)
            if ok and r then ch=r; break else retries=retries+1; task.wait(0.1) end
        end
        if not ch then return end
        scan(plot)
        plot.DescendantAdded:Connect(function() task.wait(0.1); scan(plot) end)
        plot.DescendantRemoving:Connect(function() task.wait(0.1); scan(plot) end)
        task.spawn(function() while plot.Parent do task.wait(5); scan(plot) end end)
    end

    local plots = W:WaitForChild("Plots", 8)
    if plots then
        for _, p in ipairs(plots:GetChildren()) do listen(p) end
        plots.ChildAdded:Connect(function(p) task.wait(0.5); listen(p) end)
        plots.ChildRemoved:Connect(function(p)
            last[p.Name]=nil
            for i=#cache,1,-1 do 
                if cache[i].plot==p.Name then 
                    table.remove(cache,i) 
                end 
            end
        end)
    end
end)
