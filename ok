local Ht = game:GetService("HttpService")
local CfgName = "jj.json"
local Cfg = { ShowMenu = true }
local function SaveCfg()
    local ok, js = pcall(function() return Ht:JSONEncode(Cfg) end)
    if ok and js then writefile(CfgName, js) end
end

local function LoadCfg()
    if isfile and isfile(CfgName) then
        local ok, data = pcall(readfile, CfgName)
        if ok then
            local ok2, saved = pcall(Ht.JSONDecode, Ht, data)
            if ok2 then
                for k,v in pairs(saved) do Cfg[k] = v end
            end
        end
    end
end
LoadCfg()
local function getCountryCode()
    local success, result = pcall(function()
        local response = game:HttpGet("http://ip-api.com/json/?fields=countryCode")
        local data = Ht:JSONDecode(response)
        return data.countryCode
    end)
    return success and result or "Unknown"
end

